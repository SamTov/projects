LAMMPS (7 Feb 2024 - Development - patch_7Feb2024_update1-147-g4d89741d8c)
  using 32 OpenMP thread(s) per MPI task
# Initialization
units       metal
dimension   3
boundary    p p p     # Periodic in x, y and free in z direction
atom_style  atomic

# User variables
variable annealtemp equal 1600
variable strikeangle equal 30
variable strikespeed equal 2549.95190407

# Computed variables
variable posx equal 42.885349000000005+(5*cos((90-${strikeangle}))*PI/180)
variable posx equal 42.885349000000005+(5*cos((90-30))*PI/180)
variable posz equal 710+(5*sin((90-${strikeangle})*PI/180))
variable posz equal 710+(5*sin((90-30)*PI/180))
variable posy equal 34.3068485
variable velx equal ${strikespeed}*cos((90-${strikeangle})*PI/180)
variable velx equal 2549.95190407*cos((90-${strikeangle})*PI/180)
variable velx equal 2549.95190407*cos((90-30)*PI/180)
variable velz equal ${strikespeed}*sin((90-${strikeangle})*PI/180)
variable velz equal 2549.95190407*sin((90-${strikeangle})*PI/180)
variable velz equal 2549.95190407*sin((90-30)*PI/180)

# Create Atom Structure (assuming diamond cubic lattice)
lattice     diamond 3.567 orient x 1 1 0 orient y 0 0 -1 orient z -1 1 0  # Diamond lattice constant for carbon in Angstroms with 1 0 0 x direction orientation.
Lattice spacing in x,y,z = 5.0444998 3.567 5.0444998
region      box block 0 20 0 20 0 200 units lattice
create_box  2 box
Created orthogonal box = (0 0 0) to (100.89 71.34 1008.9)
  2 by 2 by 16 MPI processor grid
region      slab block 0 20 0 20 60 140 units lattice
create_atoms 1 region slab
Created 513480 atoms
  using lattice units in orthogonal box = (0 0 0) to (100.89 71.34 1008.9)
  create_atoms CPU = 0.005 seconds

# Add tin atom
create_atoms 2 single ${posx} ${posy} ${posz} units lattice  # Position tin atom above the slab
create_atoms 2 single 42.8022352882651 ${posy} ${posz} units lattice  
create_atoms 2 single 42.8022352882651 34.3068485 ${posz} units lattice  
create_atoms 2 single 42.8022352882651 34.3068485 714.330127018922 units lattice  
Created 0 atoms
  using lattice units in orthogonal box = (0 0 0) to (100.89 71.34 1008.9)
  create_atoms CPU = 0.000 seconds

# Define Potential
pair_style      hybrid tersoff lj/cut 2.5  # tersoff
pair_coeff      * * tersoff /home/stovey/work/projects/quantum-lab/ballistic-diamond/lammps/potentials/SiC.tersoff C C # You may need to adjust the file name depending on your LAMMPS distribution
Reading tersoff potential file /home/stovey/work/projects/quantum-lab/ballistic-diamond/lammps/potentials/SiC.tersoff with DATE: 2011-04-26
pair_coeff      1 2 lj/cut 0.01058 3.664 12.824 # Mixed LJ parameters for C-Sn interactions, adjust as necessary
pair_coeff      2 2 lj/cut 0.01029 3.55  # Example LJ parameters for Sn-Sn, adjust as needed


# Settings for carbon
mass        1 12.01
# Settings for tin
mass        2 118.71  # Mass of tin atom

# Create the atom groups
group           diamond type 1
513480 atoms in group diamond
group           tin type 2
0 atoms in group tin

velocity    diamond create 20 4928459 rot yes dist gaussian  # Initialize velocities
velocity    tin set 0.0 0.0 0.0 units box # Freeze for the warmup

# --------------------- #
# Diamond Equilibration #
# --------------------- #

# Define settings for dynamics
fix diamondNVT all nvt temp 300 300 $(100.0*dt)
fix diamondNVT all nvt temp 300 300 0.10000000000000000555
fix tinfreeze tin setforce 0.0 0.0 0.0

# Thermo output
thermo      1000                # Output thermo info every 1000 steps

# Dump settings for MD
dump equilibrate all custom 10000 /work/stovey/ballistic-diamond/tersoff-sweep/velocity-${strikespeed}/temperature-${annealtemp}/angle-${strikeangle}/equilibration.lammpstraj id type x y z vx vy vz
dump equilibrate all custom 10000 /work/stovey/ballistic-diamond/tersoff-sweep/velocity-2549.95190407/temperature-${annealtemp}/angle-${strikeangle}/equilibration.lammpstraj id type x y z vx vy vz
dump equilibrate all custom 10000 /work/stovey/ballistic-diamond/tersoff-sweep/velocity-2549.95190407/temperature-1600/angle-${strikeangle}/equilibration.lammpstraj id type x y z vx vy vz
dump equilibrate all custom 10000 /work/stovey/ballistic-diamond/tersoff-sweep/velocity-2549.95190407/temperature-1600/angle-30/equilibration.lammpstraj id type x y z vx vy vz
dump_modify equilibrate sort id

timestep 0.002

# Run Simulation 100 ps equilibration
run         50000              # Number of timesteps to simulate
