# Initialization
units       metal
dimension   3
boundary    p p p     # Periodic in x, y and free in z direction
atom_style  atomic

# User variables
variable annealtemp equal 500
variable strikeangle equal 0
variable strikespeed equal 500

# Computed variables
variable posx equal 10+(5*cos((90-${strikeangle}))*PI/180)
variable posz equal 140+(5*sin((90-${strikeangle})*PI/180))
variable velx equal ${strikespeed}*cos((90-${strikeangle})*PI/180)
variable velz equal ${strikespeed}*sin((90-${strikeangle})*PI/180)

print ${velx}
print ${velz}