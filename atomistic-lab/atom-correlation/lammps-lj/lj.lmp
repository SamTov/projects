# Lennard-Jones Fluid in NVT Ensemble
units		lj
atom_style	atomic

lattice		fcc 0.8442
region		box block 0 5 0 5 0 5
create_box	1 box
create_atoms	1 box
mass		1 1.0

velocity	all create 3.0 87287 loop geom

pair_style	lj/cut 2.5
pair_coeff	1 1 1.0 1.0 2.5

# Thermostat and Dynamics
velocity all create 1.0 12345  # Set initial temperature
fix 1 all nvt temp 1.0 1.0 1.0  # NVT ensemble with target temp of 1.0 and time constant of 1.0

# Output Settings
timestep 0.005
thermo 100  # Output thermodynamic info every 100 timesteps
dump 1 all custom 1 lj_nvt.lammpstrj id type x y z vx vy vz # Save atomic positions every 100 timesteps
dump_modify 1 sort id

# Run Simulation
run 50000
