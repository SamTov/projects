## TIP4P/2005 water for Experiment 4 (water phases).
## Uses LAMMPS's tip4p long pair style and SHAKE for rigid O-H.
##
## Jinja2 context expected:
##   seed            integer RNG seed
##   data_file       LAMMPS data file with 3-site water topology
##                   (atoms numbered O=1, H=2, with bond/angle types defined)
##   temperature     target T (Kelvin)
##   pressure        target P (atm)
##   timestep        integrator dt (fs), typically 1.0 with SHAKE
##   n_equil         equilibration steps
##   n_prod          production steps
##   sample_every    dump velocity every N steps
##   out_dump        trajectory output path

units           real
atom_style      full
boundary        p p p

read_data       {{ data_file }}

# TIP4P/2005 parameters.
# Massless M site is synthesised at position 0.1546 Å from O along HOH bisector.
pair_style      lj/cut/tip4p/long 1 2 1 1 0.1546 12.0
pair_coeff      1 1 0.1852 3.1589   # O-O (ε, σ)
pair_coeff      * 2 0.0 0.0         # H interactions vanish (all through M)

bond_style      harmonic
bond_coeff      1 0.0 0.9572        # rigid, stiffness overridden by SHAKE

angle_style     harmonic
angle_coeff     1 0.0 104.52

kspace_style    pppm/tip4p 1.0e-5

fix             rigid all shake 1.0e-4 100 0 b 1 a 1

velocity        all create {{ temperature }} {{ seed }} mom yes rot yes dist gaussian

timestep        {{ timestep }}
fix             integrate all npt temp {{ temperature }} {{ temperature }} 100.0 iso {{ pressure }} {{ pressure }} 1000.0

thermo          1000
thermo_style    custom step temp press vol density

run             {{ n_equil }}

reset_timestep  0
dump            d_vel all custom {{ sample_every }} {{ out_dump }} id type xu yu zu vx vy vz
dump_modify     d_vel sort id
run             {{ n_prod }}
