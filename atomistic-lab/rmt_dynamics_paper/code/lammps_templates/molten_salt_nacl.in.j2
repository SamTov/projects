## Molten NaCl (Tosi–Fumi / Born–Mayer + Coulomb) for Experiment 5.
##
## Jinja2 context expected:
##   seed            integer RNG seed
##   data_file       LAMMPS data file with Na (type 1) / Cl (type 2) atoms
##   temperature     target T (Kelvin), typically 1100–1800
##   timestep        integrator dt (fs), typically 1.0
##   n_equil         equilibration steps
##   n_prod          production steps
##   sample_every    dump velocity every N steps
##   out_dump        trajectory output path
##   cutoff          real-space cutoff (Å) — typical 10–12

units           real
atom_style      charge
boundary        p p p

read_data       {{ data_file }}

# Tosi–Fumi-style Born–Mayer pair potential.
# Users should double-check A, ρ, C, D against Fumi & Tosi 1964 for their
# specific system (RbI, NaCl, etc.). The coefficients below are the standard
# NaCl parameters in kcal/mol and Å.
pair_style      born/coul/long {{ cutoff | default(12.0) }}
# pair_coeff <type1> <type2> A rho sigma C D     (LAMMPS Born convention)
# Placeholder coefficients — review before production runs.
pair_coeff      1 1   0.2637   0.317  2.340   1.0486   0.4993   # Na-Na
pair_coeff      1 2   0.2108   0.317  2.755   6.9906   8.6757   # Na-Cl
pair_coeff      2 2   0.1582   0.317  3.170  72.4003 145.4277   # Cl-Cl

kspace_style    pppm 1.0e-5

velocity        all create {{ temperature }} {{ seed }} mom yes rot yes dist gaussian

timestep        {{ timestep }}
fix             integrate all nvt temp {{ temperature }} {{ temperature }} 100.0

thermo          1000
thermo_style    custom step temp etotal press vol

run             {{ n_equil }}

reset_timestep  0
dump            d_vel all custom {{ sample_every }} {{ out_dump }} id type q xu yu zu vx vy vz
dump_modify     d_vel sort id
run             {{ n_prod }}
